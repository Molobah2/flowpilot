# =========================================
# FlowPilot Runner — Environment Variables
# =========================================
# Copy to apps/runner/.env and fill in values.
# NEVER commit .env files.

# Runner backend signer (testnet only, never reuse MetaMask/AGW keys)
STACKS_PRIVATE_KEY=

# Spend gate caps (micro-USDCx; 1 USDCx = 1_000_000)
FLOWPILOT_MAX_PER_EXECUTION=50000000
FLOWPILOT_MAX_PER_DAY=200000000

# Hiro API
HIRO_API_URL=https://api.testnet.hiro.so
POLL_INTERVAL_MS=10000

# Data persistence paths (relative to runner working dir)
GATE_STATE_PATH=./data/gate-state.json
IDEMPOTENCY_PATH=./data/processed-txids.json
EXECUTIONS_PATH=./data/executions.json

# FlowVault contract identifiers (testnet)
NEXT_PUBLIC_FLOWVAULT_NETWORK=testnet
NEXT_PUBLIC_FLOWVAULT_CONTRACT_ADDRESS=STD7QG84VQQ0C35SZM2EYTHZV4M8FQ0R7YNSQWPD
NEXT_PUBLIC_FLOWVAULT_CONTRACT_NAME=flowvault-v2
NEXT_PUBLIC_FLOWVAULT_TOKEN_CONTRACT_ADDRESS=ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM
NEXT_PUBLIC_FLOWVAULT_TOKEN_CONTRACT_NAME=usdcx

# Active policy as JSON string (or omit to load from policy.json)
# FLOWPILOT_POLICY={"name":"...","recipients":[...],...}
